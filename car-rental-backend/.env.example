# Copy this file to .env and fill in real values. Never commit .env to git.

# JWT signing secret — must be a long random string (32+ chars)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-secure-random-string

# MongoDB connection string
MONGODB_URL=mongodb://localhost:27017/carRental

# Server port (optional, defaults to 5001)
PORT=5001
